# ── DEVISE Environment Configuration ──────────────────────────
# Copy this file to .env and fill in your actual keys

# ALPACA PAPER TRADING (https://alpaca.markets)

# Alpaca Trade API Key ID
APCA_API_KEY_ID=your_alpaca_api_key_here
# Alpaca Trade API Secret Key
APCA_API_SECRET_KEY=your_alpaca_secret_key_here
# Alpaca API Base URL (default is paper)
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# OPENAI / LLM (optional, for future reasoning features)
OPENAI_API_KEY=sk-your-openai-key-here

# ARMORIQ (https://armoriq.io)
ARMORIQ_API_KEY=ak_live_your_armoriq_key_here

# DEVISE HMAC SECRET (generate with: openssl rand -hex 32)
DEVICE_SECRET_KEY=your_64_char_hex_secret_here

# SUPABASE (optional, for persistent audit storage)

# Supabase Project URL
SUPABASE_URL=https://your-project.supabase.co
# Supabase Anon/API Key
SUPABASE_KEY=your_supabase_anon_key_here